{
    "name": "polidog/relayer",
    "description": "Relayer — file-based router + Symfony DependencyInjection + dotenv on top of polidog/use-php.",
    "type": "library",
    "license": "MIT",
    "bin": [
        "bin/relayer"
    ],
    "autoload": {
        "psr-4": {
            "Polidog\\Relayer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Polidog\\Relayer\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "polidog",
            "email": "polidogs@gmail.com"
        }
    ],
    "replace": {
        "polidog/usephp-framework": "*"
    },
    "require": {
        "php": ">=8.5",
        "ext-curl": "*",
        "polidog/use-php": "^0.7.0",
        "symfony/dependency-injection": "^7.1",
        "symfony/config": "^7.1",
        "symfony/yaml": "^7.1",
        "psr/container": "^2.0",
        "symfony/dotenv": "^7.1",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
