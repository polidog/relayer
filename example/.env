APP_ENV=dev

# DATABASE_DSN drives Relayer's Db layer: set it and PdoDatabase ->
# CachingDatabase (-> TraceableDatabase in dev) is auto-wired, so
# UserRepository just takes a `Database` dependency. The example sets it
# in public/index.php instead of here, because SQLite resolves a relative
# DSN path against the process cwd and the entrypoint is the only place
# that knows an absolute, cwd-independent path. A real app with a server
# DB (mysql:/pgsql:) would just put the DSN here.
