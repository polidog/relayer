{
    "name": "polidog/relayer-example",
    "description": "Example app for the Relayer framework.",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require": {
        "php": ">=8.5",
        "polidog/relayer": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-install-cmd": [
            "Polidog\\UsePhp\\Installer\\AssetInstaller::publish"
        ],
        "post-update-cmd": [
            "Polidog\\UsePhp\\Installer\\AssetInstaller::publish"
        ]
    }
}
